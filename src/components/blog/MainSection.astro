---
import ReportCard from "@/components/common/ReportCard.astro";
import JourneyCard from "@/components/common/JourneyCard.astro";
import HeadingPath from "@/components/blog/HeadingPath.astro";
---

<!-- Background Animation -->
<div class="absolute inset-0 z-0 opacity-20 pointer-events-none overflow-hidden">
  <div class="scanline"></div>
</div>

<div class="relative z-10 mx-auto w-full max-w-6xl px-6 md:px-10 py-12 md:py-24">

  <!-- Header Section -->
  <HeadingPath />

  <!-- Tabs -->
  <div class="flex border-b border-outline-variant mb-12 w-full">
    <button
      class="cursor-pointer px-8 py-4 font-code-sm text-code-sm transition-all tab-active uppercase tracking-tighter flex items-center gap-2"
      id="tab-reports"
      onclick="switchTab('reports')"
    >
      <span class="material-symbols-outlined text-[18px]">description</span>
      Reports
    </button>

    <button
      class="cursor-pointer px-8 py-4 font-code-sm text-code-sm transition-all text-on-surface-variant hover:text-primary uppercase tracking-tighter flex items-center gap-2"
      id="tab-journey"
      onclick="switchTab('journey')"
    >
      <span class="material-symbols-outlined text-[18px]">route</span>
      Journey
    </button>
  </div>

  <!-- CONTENT: REPORTS -->
  <div class="block w-full" id="content-reports">

    <div class="grid grid-cols-1 gap-8 w-full">
        <!-- Report Card 1 -->
        <div class="glass-panel p-4 flex flex-col md:flex-row gap-6 hover:border-primary transition-all group">
            <div class="w-full md:w-48 h-32 overflow-hidden border border-outline-variant">
                <img alt="Report Thumbnail" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqWYqOwgk19RAk6CPTjygHGISUZqiQ8CsbAyB_YpyRDl8e4vwxIbPO7TtC6XI9zSh3CN-vXEH4BGSOghqQW5GdFlgzghHtwsdpWzu-zqy7-hZtsAeuQz50wRwXsBkto6s-UY4eXgtTqfwxtU7msx-0ZDBlf4KNXzNTRnWeirxwYSzTqXHsrp9EOzw0E9GmMGGslCGvkdeck9Y11ThmvHScjSeDn2eXlh2fxyw6-1OR8Eud15oHsa32AsofrCHCpD59VkWJyolkqT8">
            </div>
            <div class="flex-1 space-y-2">
                <div class="flex justify-between items-start">
                    <div class="flex flex-wrap gap-2"><span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">#file-system-forensics</span><span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">#NTFS</span><span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">#Artifacts</span></div>
                    <span class="text-outline font-code-sm text-xs">2024.05.12 // 14:30 UTC</span>
                </div>
                <h4 class="text-on-surface font-headline-md text-lg group-hover:text-primary transition-colors">MFT Anomaly Detection in NTFS Vol_01</h4>
                <p class="text-on-surface-variant text-sm line-clamp-2">An in-depth investigation into non-standard resident attribute artifacts found within the Master File Table of a compromised enterprise...</p>
                <div class="flex justify-between items-center pt-2">
                    <span class="text-primary font-code-sm text-xs flex items-center gap-1"><span class="material-symbols-outlined text-xs">radar</span> Lvl: ADVANCED</span>
            <a
                class="text-primary font-code-sm text-xs flex items-center gap-1"
                href="/blog_report"
            >
                <span class="hover:underline">READ</span>
                <span class="material-symbols-outlined text-xs">arrow_right_alt</span>
            </a>                </div>
            </div>
        </div>

        <!-- Report Card 2 -->
        <div class="glass-panel p-4 flex flex-col md:flex-row gap-6 hover:border-primary transition-all group">
            <div class="w-full md:w-48 h-32 overflow-hidden border border-outline-variant">
                <img alt="Report Thumbnail" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqWYqOwgk19RAk6CPTjygHGISUZqiQ8CsbAyB_YpyRDl8e4vwxIbPO7TtC6XI9zSh3CN-vXEH4BGSOghqQW5GdFlgzghHtwsdpWzu-zqy7-hZtsAeuQz50wRwXsBkto6s-UY4eXgtTqfwxtU7msx-0ZDBlf4KNXzNTRnWeirxwYSzTqXHsrp9EOzw0E9GmMGGslCGvkdeck9Y11ThmvHScjSeDn2eXlh2fxyw6-1OR8Eud15oHsa32AsofrCHCpD59VkWJyolkqT8">
            </div>
            <div class="flex-1 space-y-2">
                <div class="flex justify-between items-start">
                    <div class="flex flex-wrap gap-2"><span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">#malware-analysis</span><span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">#EDR_Bypass</span></div>
                    <span class="text-outline font-code-sm text-xs">2024.04.28 // 09:15 UTC</span>
                </div>
                <h4 class="text-on-surface font-headline-md text-lg group-hover:text-primary transition-colors">Deconstructing the 'Void-Caller' Trojan</h4>
                <p class="text-on-surface-variant text-sm line-clamp-2">Static and dynamic analysis of a new stealth loader using indirect syscalls to bypass modern EDR solutions on Windows 11 23H2.</p>
                <div class="flex justify-between items-center pt-2">
                    <span class="text-primary font-code-sm text-xs flex items-center gap-1"><span class="material-symbols-outlined text-xs">radar</span> Lvl: INTERMEDIATE</span>
            <a
                class="text-primary font-code-sm text-xs flex items-center gap-1"
                href="/blog_report"
            >
                <span class="hover:underline">READ</span>
                <span class="material-symbols-outlined text-xs">arrow_right_alt</span>
            </a>                </div>
            </div>
        </div>

        <!-- Report Card 3 -->
        <div class="glass-panel p-4 flex flex-col md:flex-row gap-6 hover:border-primary transition-all group">
            <div class="w-full md:w-48 h-32 overflow-hidden border border-outline-variant">
                <img alt="Report Thumbnail" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqWYqOwgk19RAk6CPTjygHGISUZqiQ8CsbAyB_YpyRDl8e4vwxIbPO7TtC6XI9zSh3CN-vXEH4BGSOghqQW5GdFlgzghHtwsdpWzu-zqy7-hZtsAeuQz50wRwXsBkto6s-UY4eXgtTqfwxtU7msx-0ZDBlf4KNXzNTRnWeirxwYSzTqXHsrp9EOzw0E9GmMGGslCGvkdeck9Y11ThmvHScjSeDn2eXlh2fxyw6-1OR8Eud15oHsa32AsofrCHCpD59VkWJyolkqT8">
            </div>
            <div class="flex-1 space-y-2">
                <div class="flex justify-between items-start">
                    <div class="flex flex-wrap gap-2"><span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">#osint</span><span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">#Python</span></div>
                    <span class="text-outline font-code-sm text-xs">2024.04.15 // 22:45 UTC</span>
                </div>
                <h4 class="text-on-surface font-headline-md text-lg group-hover:text-primary transition-colors">Automating Social Signal Intelligence</h4>
                <p class="text-on-surface-variant text-sm line-clamp-2">Developing custom Python scrapers for mapping influence operations across decentralized social networks using Graph theory.</p>
                <div class="flex justify-between items-center pt-2">
                    <span class="text-primary font-code-sm text-xs flex items-center gap-1"><span class="material-symbols-outlined text-xs">radar</span> Lvl: RESEARCH</span>
            <a
                class="text-primary font-code-sm text-xs flex items-center gap-1"
                href="/blog_report"
            >
                <span class="hover:underline">READ</span>
                <span class="material-symbols-outlined text-xs">arrow_right_alt</span>
            </a>                </div>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    <div class="mt-12 pt-8 border-t border-outline-variant flex flex-col md:flex-row justify-between items-center gap-6 w-full">
      <button class="cursor-pointer flex items-center gap-2 text-on-surface-variant hover:text-primary">
        <span class="material-symbols-outlined">chevron_left</span>
        PREV_PAGE
      </button>

      <div class="flex items-center gap-2">
        <button class="cursor-pointer w-10 h-10 border border-primary bg-primary/10 text-primary">01</button>
        <button class="cursor-pointer w-10 h-10 border border-outline-variant text-on-surface-variant">02</button>
        <button class="cursor-pointer w-10 h-10 border border-outline-variant text-on-surface-variant">03</button>
      </div>

      <button class="cursor-pointer flex items-center gap-2 text-on-surface-variant hover:text-primary">
        NEXT_PAGE
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>

  </div>

  <!-- CONTENT: JOURNEY -->
  <div class="hidden w-full" id="content-journey">

    <div class="max-w-4xl mx-auto space-y-6">

<!-- 1. Khóa học ZKP -->
<div class="glass-panel cursor-pointer p-4 flex flex-col md:flex-row gap-6 hover:border-primary transition-all group">
    <div class="w-full md:w-48 h-32 overflow-hidden border border-outline-variant">
        <img
            alt="ZKP Course Thumbnail"
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all"
            src="https://media.licdn.com/dms/image/v2/C560BAQF0bCMJ-hsnJA/company-logo_200_200/company-logo_200_200/0/1672292992659/zkp_labs_viet_nam_logo?e=2147483647&v=beta&t=AbHThzYzel9stpIr4EPgXz_fmUy44xX2l5S2qM-7QGQ"
        />
    </div>

    <div class="flex-1 space-y-2">
        <div class="flex justify-between items-start">
            <div class="flex flex-wrap gap-2">
                <span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">
                    #ZKP
                </span>

                <span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">
                    #Cryptography
                </span>

                <span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">
                    #Blockchain
                </span>
            </div>

            <span class="text-outline font-code-sm text-xs">
                2025.07.10
            </span>
        </div>

        <h4 class="text-on-surface font-headline-md text-lg group-hover:text-primary transition-colors">
            Zero-Knowledge Proof (ZKP) Foundation Course
        </h4>

        <p class="text-on-surface-variant text-sm line-clamp-2">
            A comprehensive learning journey covering Zero-Knowledge Proof fundamentals,
            zk-SNARKs, zk-STARKs, and practical applications in modern blockchain systems.
        </p>

        <div class="flex justify-end items-center pt-2">
            <a
                class="text-primary font-code-sm text-xs flex items-center gap-1"
                href="#"
            >
                <span class="hover:underline">READ</span>
                <span class="material-symbols-outlined text-xs">arrow_right_alt</span>
            </a>
        </div>
    </div>
</div>

<!-- 2. Giải Vô Địch Karate VKU -->
<div class="glass-panel cursor-pointer p-4 flex flex-col md:flex-row gap-6 hover:border-primary transition-all group">
    <div class="w-full md:w-48 h-32 overflow-hidden border border-outline-variant">
        <img
            alt="Karate Championship Thumbnail"
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all"
            src="src/assets/avt.jpg"
        />
    </div>

    <div class="flex-1 space-y-2">
        <div class="flex justify-between items-start">
            <div class="flex flex-wrap gap-2">
                <span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">
                    #Karate
                </span>

                <span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">
                    #VKU
                </span>

                <span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">
                    #Championship
                </span>
            </div>

            <span class="text-outline font-code-sm text-xs">
                2025.04.21
            </span>
        </div>

        <h4 class="text-on-surface font-headline-md text-lg group-hover:text-primary transition-colors">
            VKU Karate Championship 2025
        </h4>

        <p class="text-on-surface-variant text-sm line-clamp-2">
            Competing alongside talented athletes across multiple weight classes,
            demonstrating discipline, perseverance, and sportsmanship throughout the tournament.
        </p>

        <div class="flex justify-end items-center pt-2">
            <a
                class="text-primary font-code-sm text-xs flex items-center gap-1"
                href="#"
            >
                <span class="hover:underline">READ</span>
                <span class="material-symbols-outlined text-xs">arrow_right_alt</span>
            </a>
        </div>
    </div>
</div>

<!-- 3. Thực tập doanh nghiệp VNNIC -->
<div class="glass-panel cursor-pointer p-4 flex flex-col md:flex-row gap-6 hover:border-primary transition-all group">
    <div class="w-full md:w-48 h-32 overflow-hidden border border-outline-variant">
        <img
            alt="VNNIC Internship Thumbnail"
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all"
            src="https://adina.com.vn/wp-content/uploads/2021/09/Thiet-ke-bo-logo-thuong-hieu-VINNIC-1.jpg"
        />
    </div>

    <div class="flex-1 space-y-2">
        <div class="flex justify-between items-start">
            <div class="flex flex-wrap gap-2">
                <span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">
                    #Internship
                </span>

                <span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">
                    #VNNIC
                </span>

                <span class="text-primary font-code-sm text-xs bg-primary/10 px-2 py-0.5 border border-primary/20">
                    #Networking
                </span>
            </div>

            <span class="text-outline font-code-sm text-xs">
                2025.06.01
            </span>
        </div>

        <h4 class="text-on-surface font-headline-md text-lg group-hover:text-primary transition-colors">
            Enterprise Internship at VNNIC
        </h4>

        <p class="text-on-surface-variant text-sm line-clamp-2">
            Participating in real-world networking projects, collaborating with engineers,
            and gaining hands-on experience in Internet infrastructure and cybersecurity.
        </p>

        <div class="flex justify-end items-center pt-2">
            <a
                class="text-primary font-code-sm text-xs flex items-center gap-1"
                href="#"
            >
                <span class="hover:underline">READ</span>
                <span class="material-symbols-outlined text-xs">arrow_right_alt</span>
            </a>
        </div>
    </div>
</div>

    </div>

  </div>

</div>
<script>
  function switchTab(tab) {
    const reportsContent = document.getElementById('content-reports');
    const journeyContent = document.getElementById('content-journey');
    const reportsTab = document.getElementById('tab-reports');
    const journeyTab = document.getElementById('tab-journey');

    if (tab === 'reports') {
      reportsContent?.classList.remove('hidden');
      reportsContent?.classList.add('block');
      journeyContent?.classList.add('hidden');
      journeyContent?.classList.remove('block');

      reportsTab?.classList.add('tab-active');
      reportsTab?.classList.remove('text-on-surface-variant');
      journeyTab?.classList.remove('tab-active');
      journeyTab?.classList.add('text-on-surface-variant');
    } else {
      journeyContent?.classList.remove('hidden');
      journeyContent?.classList.add('block');
      reportsContent?.classList.add('hidden');
      reportsContent?.classList.remove('block');

      journeyTab?.classList.add('tab-active');
      journeyTab?.classList.remove('text-on-surface-variant');
      reportsTab?.classList.remove('tab-active');
      reportsTab?.classList.add('text-on-surface-variant');
    }
  }

  window.switchTab = switchTab;

  document.querySelectorAll('.font-code-sm').forEach(el => {
    el.addEventListener('mouseenter', () => {
      el.style.opacity = '0.7';
      setTimeout(() => el.style.opacity = '1', 100);
    });
  });
</script>
