---
import ReportCard from '@/components/common/ReportCard.astro';
---

<div class="lg:col-span-8 space-y-8 lg:pl-4">
    <!-- Section Header -->
    <div class="flex justify-between items-end border-b border-outline-variant pb-4">
        <div class="flex items-center gap-2 text-primary">
            <span class="material-symbols-outlined">terminal</span>
            <h3 class="font-display-lg text-headline-md tracking-tight uppercase">
                LATEST_REPORTS
            </h3>
        </div>

        <span class="font-code-sm text-label-xs text-outline">
            DISPLAY_3_REPORTS
        </span>
    </div>

    <!-- Report List -->
    <div class="space-y-8">
        <!-- Report Card -->
        <ReportCard />
        <ReportCard />
        <ReportCard />
    </div>

    <!-- View All -->
    <div class="flex justify-center pt-12">
        <a
            href="#"
            class="group flex items-center gap-3 border border-primary bg-surface-container-high px-10 py-3 font-code-sm text-primary transition-all duration-300 hover:bg-primary hover:text-on-primary-container"
        >
            <span class="material-symbols-outlined text-sm group-hover:animate-pulse">
                terminal
            </span>
            VIEW ALL REPORTS
        </a>
    </div>
</div>
