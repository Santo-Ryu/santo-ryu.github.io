---
const recentTags = [
    "#Malware_Analysis",
    "#SIEM",
    "#ELK_Stack",
    "#YARA",
];
---

<aside class="space-y-8 pt-[45px] lg:col-span-4 lg:pr-4 lg:pt-[45px]">
    <!-- Identity -->
    <section class="space-y-4 border border-outline-variant bg-surface-container-low p-4">
        <h4 class="border-b border-outline-variant pb-2 font-code-sm uppercase tracking-widest text-primary">
            IDENTITY
        </h4>

        <p class="text-sm text-on-surface-variant">
            A personal knowledge base for cybersecurity. 
            Sharing writeups, DFIR investigations, malware analysis, Blue Team labs.
        </p>

        <div class="space-y-2 pt-4">
            <span class="font-code-sm text-label-xs text-outline">
                PGP_FINGERPRINT:
            </span>

            <div class="break-all border border-outline-variant bg-surface-container-lowest p-3 font-code-sm text-xs text-primary">
                8EA6 A11E 82AF 8579 F5A3
                <br />
                F4E4 1EFC 96E9 9B11 8F89
            </div>
        </div>
    </section>

    <!-- Recent Tags -->
    <section class="space-y-4">
        <h4 class="border-b border-outline-variant pb-2 font-code-sm uppercase tracking-widest text-primary">
            RECENT_TAGS
        </h4>

        <div class="flex flex-wrap gap-2">
            {
                recentTags.map((tag) => (
                    <a
                        href="#"
                        class="border border-outline-variant bg-surface-container-high px-3 py-1.5 font-code-sm text-label-xs transition-all hover:border-primary"
                    >
                        {tag}
                    </a>
                ))
            }

            <a
                href="#"
                class="px-3 py-1.5 font-code-sm text-label-xs text-outline underline underline-offset-4 transition-all hover:text-primary"
            >
                Other...
            </a>
        </div>
    </section>

    <!-- Signal Intercept -->
    <section class="group relative overflow-hidden border border-outline-variant bg-surface-container p-4">
        <div class="absolute -right-4 -bottom-4 text-primary/5 transition-colors group-hover:text-primary/10">
            <span class="material-symbols-outlined text-[120px]">
                sensors
            </span>
        </div>

        <div class="relative z-10 space-y-4">
            <h4 class="border-b border-outline-variant pb-2 font-code-sm uppercase tracking-widest text-primary">
                CURRENT_STATUS
            </h4>

            <p class="text-sm text-on-surface-variant">
                Internship at VNNIC Da Nang <br> <br>
                Last Update: 2026-07-09
            </p>
        </div>
    </section>
</aside>
