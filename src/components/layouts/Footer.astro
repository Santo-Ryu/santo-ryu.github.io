---
const footerLinks = [
    { name: "GitHub", href: "#" },
    { name: "LinkedIn", href: "#" },
    { name: "RSS", href: "#" },
    { name: "Contact", href: "#" },
];
---

<footer class="mt-24 border-t border-outline-variant bg-surface-container-lowest">
    <div
        class="mx-auto flex max-w-container-max flex-col items-center justify-between gap-6 px-margin-mobile py-8 md:flex-row md:px-margin-desktop"
    >
        <div class="flex flex-col items-center gap-2 md:items-start">
            <span
                class="font-code-sm text-code-sm font-bold tracking-tighter text-on-surface-variant"
            >
                SANTO-RYU
            </span>

            <span class="font-code-sm text-code-sm text-on-surface-variant opacity-60">
                © 2024 SANTO-RYU // DIGITAL FORENSICS RESEARCH
            </span>
        </div>

        <nav class="flex flex-wrap items-center gap-8">
            {
                footerLinks.map((link) => (
                    <a
                        href={link.href}
                        class="font-code-sm text-code-sm text-on-surface-variant transition-colors hover:text-primary"
                    >
                        {link.name}
                    </a>
                ))
            }
        </nav>
    </div>
</footer>
