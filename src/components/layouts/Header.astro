---
interface Props {
    currentPage: "Home" | "Blog" | "Tags" | "Archives" | "About";
}

const { currentPage = "Home" } = Astro.props;

const navItems = [
    { name: "Home", href: "/" },
    { name: "Blog", href: "/blog" },
    { name: "Archives", href: "/archive" },
    { name: "About", href: "/about" },
];
---

<header class="sticky top-0 z-50 border-b border-outline-variant bg-surface">
    <div
        class="mx-auto flex h-20 max-w-container-max items-center justify-between px-margin-mobile md:px-margin-desktop"
    >
        <!-- Logo -->
        <a
            href="/"
            class="font-display-lg text-headline-md font-bold tracking-tighter text-primary md:text-display-lg"
        >
            SANTO-<span class="text-on-surface">RYU</span>
        </a>

        <!-- Desktop Menu -->
        <nav class="hidden items-center gap-8 lg:flex">
        {
            navItems.map((item) => (
            <a
                href={item.href}
                class="relative pl-3 text-on-surface-variant transition-colors duration-200 hover:text-primary before:absolute before:left-0 before:top-1/2 before:h-7 before:w-1 before:-translate-y-1/2 before:scale-y-0 before:bg-primary before:transition-transform before:duration-200 hover:before:scale-y-100"
            >
                {item.name}
            </a>
            ))
        }
        </nav>

        <!-- Mobile Menu Button -->
        <button
            id="menu-btn"
            class="rounded-md p-2 transition hover:bg-surface-container lg:hidden"
            aria-label="Toggle menu"
        >
            <span
                id="menu-icon"
                class="material-symbols-outlined text-3xl"
            >
                menu
            </span>
        </button>
    </div>

    <!-- Mobile Menu -->
    <nav
        id="mobile-menu"
        class="hidden border-t border-outline-variant bg-surface lg:hidden"
    >
        <div class="flex flex-col p-4">
            {
                navItems.map((item) => (
                    <a
                        href={item.href}
                        class:list={[
                            "rounded px-3 py-3 transition",

                            currentPage === item.name
                                ? "bg-primary/10 font-semibold text-primary"
                                : "text-on-surface-variant hover:bg-surface-container hover:text-primary",
                        ]}
                    >
                        {item.name}
                    </a>
                ))
            }
        </div>
    </nav>
</header>

<script>
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");
    const icon = document.getElementById("menu-icon");

    function closeMenu() {
        menu?.classList.add("hidden");
        if (icon) icon.textContent = "menu";
    }

    btn?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");

        if (icon) {
            icon.textContent = menu?.classList.contains("hidden")
                ? "menu"
                : "close";
        }
    });

    // Đóng menu khi resize lên desktop
    window.addEventListener("resize", () => {
        if (window.innerWidth >= 1024) {
            closeMenu();
        }
    });

    // Đóng menu khi click vào item
    menu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMenu);
    });
</script>
